# Database
DATABASE_URL="postgresql://admin:admin123@localhost:5432/erp_core?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Application
PORT=3000

# Authentication
JWT_SECRET="super-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# Rate Limiting & Lockout (RNF07)
REDIS_URL="redis://localhost:6379"
THROTTLE_TTL=60
THROTTLE_LIMIT=5
LOCKOUT_FAILURES=5
LOCKOUT_TTL=1800

