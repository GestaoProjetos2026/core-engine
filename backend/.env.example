# Database
DATABASE_URL="postgresql://admin:admin123@localhost:5432/erp_core?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Application
PORT=3000

# Authentication
JWT_SECRET="super-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# Rate Limiting & Lockout (RNF07)
REDIS_URL="redis://localhost:6379"
THROTTLE_TTL=60
THROTTLE_LIMIT=5
LOCKOUT_FAILURES=5
LOCKOUT_TTL=1800

# Database seed (startup / npm run prisma:seed)
# Production: set all SEED_* values via cluster secrets (ArgoCD/K8s). Never commit real passwords.
SEED_ON_STARTUP=true
SEED_STRICT=false
# In production, defaults to false — set true only for controlled password rotation
SEED_UPDATE_PASSWORDS=false
# Optional strict mode for M2M secrets in production.
# false (default): allows demo fallback when SEED_M2M_SECRET_* is missing.
# true: fails startup if any required SEED_M2M_SECRET_* is missing.
SEED_STRICT_M2M_SECRETS=false

# Admin user passwords (required in NODE_ENV=production if seed runs)
# SEED_PASSWORD_ADMIN_CORE=
# SEED_PASSWORD_ADMIN_HOTMAIL=
# SEED_PASSWORD_ADMIN_CRM=
# SEED_PASSWORD_ADMIN_FISCAL=
# SEED_PASSWORD_ADMIN_DESK=
# SEED_PASSWORD_ADMIN_DEVOPS=
# SEED_PASSWORD_VIEWER=

# M2M client secrets (required in production; test-client-id always uses fixed test-client-secret)
# SEED_M2M_SECRET_CORE=
# SEED_M2M_SECRET_HOTMAIL=
# SEED_M2M_SECRET_CRM=
# SEED_M2M_SECRET_FISCAL=
# SEED_M2M_SECRET_DESK=
# SEED_M2M_SECRET_DEVOPS=
# SEED_M2M_SECRET_FINANCE_FISCAL=
# SEED_M2M_SECRET_CRM_LEADS=
# SEED_M2M_SECRET_SERVICE_DESK=

