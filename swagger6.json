ntials and scope management (RF14–RF16)"},{"name":"Integration","description":"Machine-to-machine token endpoint (RF17, RF21, RF22)"}],"servers":[{"url":"http://localhost:3000","description":"Local development"}],"components":{"securitySchemes":{"bearer":{"scheme":"bearer","bearerFormat":"JWT","type":"http","description":"JWT access token. Obtain via `POST /v1/auth/login` (user_access) or `POST /v1/integration/token` (integration_access)."}},"schemas":{}}}