{
  "name": "erp-core-auth",
  "version": "1.0.0",
  "description": "Core Engine & Auth (Core-Engine) - IAM + Integration Core",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "test": "vitest run --exclude \"dist/**\"",
    "test:unit": "vitest run src --exclude \"dist/**\"",
    "test:e2e": "vitest run test --exclude \"dist/**\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"README.md\" \"docs/CONTEXT.md\" \"docs/PRD_DEVELOPMENT.md\" \"package.json\" \"tsconfig.json\" \"eslint.config.mjs\" \".prettierrc.json\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"README.md\" \"docs/CONTEXT.md\" \"docs/PRD_DEVELOPMENT.md\" \"package.json\" \"tsconfig.json\" \"eslint.config.mjs\" \".prettierrc.json\" \".github/workflows/*.yml\"",
    "ci": "npm run lint && npm run format:check && npm run test:unit && npm run test:e2e && npm run build",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "rate-limiter-flexible": "^11.0.2",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.4.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  }
}
